{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "11",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["TEST_DATABASE_URL", "DATABASE_URL"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
