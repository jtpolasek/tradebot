    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  }
}
