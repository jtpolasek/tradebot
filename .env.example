# Database
DATABASE_URL=postgres://tradebot:tradebot@localhost:5433/tradebot
TEST_DATABASE_URL=postgres://tradebot:tradebot@localhost:5434/tradebot_test

# Alchemy API keys (copy from old app's .env.local)
ALCHEMY_API_KEY=
# Separate Alchemy key for Base; falls back to ALCHEMY_API_KEY if blank
BASE_ALCHEMY_API_KEY=

# Optional QuickNode fallback endpoints (leave blank if none)
QUICKNODE_ETH_WS=
QUICKNODE_BASE_WS=

# 0x quote API key — RETIRED. 0x no longer serves our calls; config strips this value, so
# setting it has no effect. Left here only to document the removed integration.
ZEROX_API_KEY=

# Auth key for apps/api requests (any random string)
API_KEY=

# apps/api server port
API_PORT=3001

# apps/web: URL of the API server. This is only used server-side by the Next.js API proxy.
API_URL=http://localhost:3001

# CORS: allowed dashboard origin for the API server
CORS_ORIGIN=http://localhost:3000

# Paper trading settings
PAPER_STARTING_CASH_USD=100000
BASE_TRADE_PCT=0.01
MAX_TRADE_PCT=0.03
MIN_NOTIONAL_USD=50
MIN_LIQUIDITY_USD=150000
# Max age (seconds) of a confirmed signal before the engine vetoes it as stale (skip reason
# "stale-signal"). Guards against copying backfilled, long-dead trades at the current price.
MAX_SIGNAL_AGE_SEC=180
COPY_DELAY_PENALTY_BPS_ETH=10
COPY_DELAY_PENALTY_BPS_BASE=5
GAS_USD_ETH=4
GAS_USD_BASE=0.03
# fixed | proportional
SIZING_MODE=fixed
# When false, auto-buys skip prices that only came from fallback aggregators like DefiLlama.
ALLOW_FALLBACK_PRICE_BUYS=false
# Auto-buys skip V3/Aerodrome spot prices that diverge from short TWAP by more than this.
MAX_SPOT_TWAP_DIVERGENCE_BPS=300
# Reject Chainlink ETH/USD rounds older than this (seconds); a stale feed falls back to DefiLlama.
MAX_CHAINLINK_STALENESS_SEC=3600

# Health & metrics (runner heartbeat → apps/api /health and /metrics)
# How often the runner writes its heartbeat row.
HEARTBEAT_INTERVAL_MS=10000
# Heartbeat older than this ⇒ runner reported down.
HEARTBEAT_STALE_SEC=30
# chain_state.updated_at older than this (per chain) ⇒ degraded.
CHAIN_STALE_SEC_ETH=60
CHAIN_STALE_SEC_BASE=30
# Polymarket poller (Polygon) freshness threshold — generous vs the poll interval below.
CHAIN_STALE_SEC_POLYGON=120
# Runner RSS over this (MB) ⇒ degraded (soak memory-leak guard).
RSS_SOFT_LIMIT_MB=1536

# Polymarket (watch + record only) — polls the public Data API per watched polygon wallet.
POLYMARKET_POLL_MS=20000
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com

# Logging
LOG_LEVEL=info
