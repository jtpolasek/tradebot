# Database
DATABASE_URL=postgres://tradebot:tradebot@localhost:5433/tradebot
TEST_DATABASE_URL=postgres://tradebot:tradebot@localhost:5434/tradebot_test

# Alchemy API keys (copy from old app's .env.local)
ALCHEMY_API_KEY=
# Separate Alchemy key for Base; falls back to ALCHEMY_API_KEY if blank
BASE_ALCHEMY_API_KEY=

# Optional QuickNode fallback endpoints (leave blank if none)
QUICKNODE_ETH_WS=
QUICKNODE_BASE_WS=

# 0x quote API key (copy from old app)
ZEROX_API_KEY=

# Auth key for apps/api requests (any random string)
API_KEY=

# apps/api server port
API_PORT=3001

# apps/web: URL of the API server. This is only used server-side by the Next.js API proxy.
API_URL=http://localhost:3001

# CORS: allowed dashboard origin for the API server
CORS_ORIGIN=http://localhost:3000

# Paper trading settings
PAPER_STARTING_CASH_USD=100000
BASE_TRADE_PCT=0.01
MAX_TRADE_PCT=0.03
MIN_NOTIONAL_USD=50
MIN_LIQUIDITY_USD=150000
# Max age (seconds) of a confirmed signal before the engine vetoes it as stale (skip reason
# "stale-signal"). Guards against copying backfilled, long-dead trades at the current price.
MAX_SIGNAL_AGE_SEC=180
COPY_DELAY_PENALTY_BPS_ETH=10
COPY_DELAY_PENALTY_BPS_BASE=5
GAS_USD_ETH=4
GAS_USD_BASE=0.03
# fixed | proportional
SIZING_MODE=fixed
# When false, auto-buys skip prices that only came from fallback aggregators like DefiLlama.
ALLOW_FALLBACK_PRICE_BUYS=false
# Auto-buys skip V3/Aerodrome spot prices that diverge from short TWAP by more than this.
MAX_SPOT_TWAP_DIVERGENCE_BPS=300

# Logging
LOG_LEVEL=info
